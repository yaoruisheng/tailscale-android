 var stdDialer net.Dialer
 
+// use WebSocket by default; set to "0" to fallback to HTTP/HTTPS
+var forceWebSocket = func() bool {return envknob.BoolDefaultTrue("TS_FORCE_CONTROL_WEBSOCKET")}
+
+func (a *Dialer) dialWebSocket(ctx context.Context, optAddr netip.Addr, optACEHost string) (*ClientConn, error) {
+	init, cont, err := controlbase.ClientDeferred(a.MachineKey, a.ControlKey, a.ProtocolVersion)
+	if err != nil {
+		return nil, err
+	}
+
+	wsScheme := "wss"
+	host := a.Hostname
+
+	if a.HTTPSPort == "" {
+		wsScheme = "ws"
+		if a.HTTPPort != "" && a.HTTPPort != "80" {
+			host = net.JoinHostPort(host, a.HTTPPort)
+		}
+	} else if a.HTTPSPort != "443" {
+		host = net.JoinHostPort(host, a.HTTPSPort)
+	} else {
+		if a.HTTPPort != "" && a.HTTPPort != "80" {
+			wsScheme = "ws"
+			host = net.JoinHostPort(host, a.HTTPPort)
+		}
+	}
+
+	wsURL := &url.URL{
+		Scheme: wsScheme,
+		Host:   host,
+		Path:   serverUpgradePath,
+		RawQuery: url.Values{
+			controlhttpcommon.HandshakeHeaderName: []string{base64.StdEncoding.EncodeToString(init)},
+		}.Encode(),
+	}
+
+	dialCtx, dialCancel := context.WithTimeout(ctx, 30*time.Second)
+	defer dialCancel()
+
+	wsConn, _, err := websocket.Dial(dialCtx, wsURL.String(), &websocket.DialOptions{
+		Subprotocols: []string{controlhttpcommon.UpgradeHeaderValue},
+	})
+	if err != nil {
+		return nil, err
+	}
+
+	raw := wsconn.NetConn(context.Background(), wsConn, websocket.MessageBinary, wsURL.String())
+
+	handshakeCtx, handshakeCancel := context.WithTimeout(dialCtx, 15*time.Second)
+	defer handshakeCancel()
+
+	if deadline, ok := handshakeCtx.Deadline(); ok {
+		raw.SetDeadline(deadline)
+		defer raw.SetDeadline(time.Time{})
+	}
+
+	cbConn, err := cont(handshakeCtx, raw)
+	if err != nil {
+		wsConn.Close(websocket.StatusPolicyViolation, "noise handshake failed")
+		return nil, err
+	}
+
+	return &ClientConn{Conn: cbConn}, nil
+}
+
