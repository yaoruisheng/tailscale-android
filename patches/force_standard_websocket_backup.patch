+var forceWebSocket = func() bool {return envknob.BoolDefaultTrue("TS_FORCE_CONTROL_WEBSOCKET")} // use WebSocket by default; set to "0" to fallback to HTTP/HTTPS
+
+// Safe connection wrapper to prevent panic during underlying read/write operations
+type safeNetConn struct {
+	net.Conn
+	closed atomic.Bool
+	logf   func(string, ...any)
+}
+
+func (c *safeNetConn) markClosed() {
+	c.closed.Store(true)
+}
+
+func (c *safeNetConn) Read(b []byte) (n int, err error) {
+	if c.closed.Load() {
+		return 0, io.ErrClosedPipe
+	}
+	defer func() {
+		if r := recover(); r != nil {
+			if c.logf != nil {
+				c.logf("[safeNetConn] panic in Read: %v", r)
+			}
+			err = io.ErrUnexpectedEOF
+		}
+	}()
+	return c.Conn.Read(b)
+}
+
+func (c *safeNetConn) Write(b []byte) (n int, err error) {
+	if c.closed.Load() {
+		return 0, io.ErrClosedPipe
+	}
+	defer func() {
+		if r := recover(); r != nil {
+			if c.logf != nil {
+				c.logf("[safeNetConn] panic in Write: %v", r)
+			}
+			err = io.ErrUnexpectedEOF
+		}
+	}()
+	return c.Conn.Write(b)
+}
+
+func (c *ClientConn) Close() error {
+	if c.stopHeartbeat != nil {
+		c.stopHeartbeat()
+	}
+	if c.safeConn != nil {
+		c.safeConn.markClosed()
+	}
+	return c.Conn.Close()
+}
+
+// Keep-alive function essential for Android/mobile networks.
+// It proactively closes the connection on failure to trigger reconnection logic.
+func keepAlive(
+	ctx context.Context,
+	stopHeartbeat context.CancelFunc,
+	wsConn *websocket.Conn,
+	logf func(string, ...any),
+) {
+	// Initial random delay of 1–5 seconds to avoid ping failure immediately after dialing
+	delay := time.Duration(1+rand.Intn(5)) * time.Second
+	select {
+	case <-ctx.Done():
+		return
+	case <-time.After(delay):
+	}
+
+	ticker := time.NewTicker(30 * time.Second)
+	defer ticker.Stop()
+
+	for {
+		select {
+		case <-ctx.Done():
+			if logf != nil {
+				logf("[v2] controlhttp: websocket keepalive stopped: %v", ctx.Err())
+			}
+			return
+		case <-ticker.C:
+			pingCtx, cancel := context.WithTimeout(ctx, 5*time.Second)
+			err := wsConn.Ping(pingCtx)
+			cancel()
+
+			if err != nil {
+				if logf != nil {
+					logf("[v2] controlhttp: websocket keepalive ping failed: %v. Cancelling conn.", err)
+				}
+				stopHeartbeat()
+				return
+			}
+		}
+	}
+}
+
+func (a *Dialer) dialWebSocket(ctx context.Context, optAddr netip.Addr, optACEHost string) (*ClientConn, error) {
+	// Generate handshake data
+	init, cont, err := controlbase.ClientDeferred(a.MachineKey, a.ControlKey, a.ProtocolVersion)
+	if err != nil {
+		return nil, err
+	}
+
+	// Build WebSocket URL
+	wsScheme := "wss"
+	host := a.Hostname
+
+	if a.HTTPSPort == "" {
+		// Case 1: HTTPS explicitly disabled → fallback to HTTP/ws
+		wsScheme = "ws"
+		if a.HTTPPort != "" && a.HTTPPort != "80" {
+			host = net.JoinHostPort(host, a.HTTPPort)
+		}
+	} else if a.HTTPSPort != "443" {
+		// Case 2: HTTPS enabled but non-standard port → keep wss
+		host = net.JoinHostPort(host, a.HTTPSPort)
+		// wsScheme stays "wss"
+	} else {
+		// Case 3: HTTPS enabled on standard port 443
+		// Only downgrade to ws if HTTPPort is explicitly non-standard
+		if a.HTTPPort != "" && a.HTTPPort != "80" {
+			wsScheme = "ws"
+			host = net.JoinHostPort(host, a.HTTPPort)
+		}
+	}
+
+	wsURL := &url.URL{
+		Scheme: wsScheme,
+		Host:   host,
+		Path:   serverUpgradePath,
+		RawQuery: url.Values{
+			controlhttpcommon.HandshakeHeaderName: []string{base64.StdEncoding.EncodeToString(init)},
+		}.Encode(),
+	}
+
+	// Establish WebSocket connection
+	wsConn, _, err := websocket.Dial(ctx, wsURL.String(), &websocket.DialOptions{
+		Subprotocols: []string{controlhttpcommon.UpgradeHeaderValue},
+	})
+	if err != nil {
+		return nil, err
+	}
+
+	// Create a context independent of the dialing ctx, but controlled by the 
+	// Close method of the connection object to manage the heartbeat lifecycle.
+	connCtx, stopHeartbeat := context.WithCancel(context.Background())
+	cleanup := true
+	defer func() {
+		if cleanup {
+			// Stop the heartbeat and close the connection only if handshake 
+			// fails and manual cleanup is required.
+			stopHeartbeat() 
+			_ = wsConn.Close(websocket.StatusInternalError, "setup failed")
+		}
+	}()
+
+	// Start heartbeat (attached to connCtx rather than the ephemeral dialing ctx)
+	go keepAlive(connCtx, stopHeartbeat, wsConn, a.logf)
+
+	// Adapt to net.Conn and add panic protection
+	netConn := wsconn.NetConn(connCtx, wsConn, websocket.MessageBinary, wsURL.String())
+	safeConn := &safeNetConn{Conn: netConn, logf: a.logf,}
+
+	// Complete Noise handshake
+	cbConn, err := cont(ctx, safeConn)
+	if err != nil {
+		return nil, err // Triggers defer cleanup
+	}
+
+	// Handshake successful, transfer ownership of resources.
+	// connCtx and stopHeartbeat are now managed by the returned ClientConn.
+	cleanup = false
+	return &ClientConn{
+		Conn:    cbConn,
+		stopHeartbeat: stopHeartbeat, // Hand over heartbeat control
+		safeConn:      safeConn,
+	}, nil
+}
